NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bản GitHub Pages miễn phí không cần Supabase.
# Chỉ điền các biến dưới đây khi muốn dùng database/auth/realtime tập trung.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Chỉ dùng ở server-side scripts nếu cần. Không bao giờ đưa service role lên frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
